          "id": "320f9eae-c729a4",
          "song_id": "320f9eae",
          "index": 2,
          "start_time": 55.97,
          "end_time": 85.01,
          "lyrics": "抬頭尋找天空的翅膀 候鳥出現它的影跡\n帶來遠處的飢荒 無情的戰火 依然存在的消息\n玉山白雪飄零 燃燒少年的心\n使真情溶化成音符 傾訴遙遠的祝福",
          "difficulty": "normal",
          "is_chorus": false,
          "status": "claimed",
          "claim_count": 1,
          "submit_count": 1,

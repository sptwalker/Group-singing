# ===== 应用 =====
DEBUG=true

# ===== MySQL =====
# 方式 A：直接给完整 URL（优先）
# DATABASE_URL=mysql+pymysql://youdoo:youdoo@localhost:3306/youdoo_sing?charset=utf8mb4

# 方式 B：分项配置（DATABASE_URL 为空时使用）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=youdoo
MYSQL_PASSWORD=youdoo
MYSQL_DB=youdoo_sing

# docker-compose 用的 root 密码
MYSQL_ROOT_PASSWORD=rootpassword

# ===== Redis（保留，未启用） =====
REDIS_URL=redis://localhost:6379/0

# ===== AI API（用于歌词智能分配、副歌识别、难度评估）=====
OPENAI_API_KEY=
# 可选：自定义 API 地址（默认 SiliconFlow）
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
# 可选：自定义聊天模型（默认 DeepSeek-V3）
OPENAI_CHAT_MODEL=deepseek-ai/DeepSeek-V3

# ===== WeChat H5 OAuth =====
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_OAUTH_REDIRECT_URI=

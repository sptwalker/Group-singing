# AI API 配置（用于歌词智能分配、副歌识别、难度评估）
OPENAI_API_KEY=sk-your-api-key-here
# 可选：自定义 API 地址（默认使用 SiliconFlow）
# OPENAI_BASE_URL=https://api.siliconflow.cn/v1
# 可选：自定义聊天模型（默认 DeepSeek-V3）
# OPENAI_CHAT_MODEL=deepseek-ai/DeepSeek-V3

# WeChat H5 OAuth
# WECHAT_APP_ID=wx-your-app-id
# WECHAT_APP_SECRET=your-wechat-app-secret
# Optional relay or public callback URL.
# Example: WECHAT_OAUTH_REDIRECT_URI=https://wxcb.youdoogo.com/sing
